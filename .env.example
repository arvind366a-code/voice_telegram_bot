# Copy to .env and fill in. .env is gitignored.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# OpenAI API key (used for Whisper transcription)
OPENAI_API_KEY=

# Your Telegram numeric user id — ONLY this user's voice notes are analyzed
OWNER_USER_ID=

# Optional second reviewer's user id (they only view reports; their voice notes are ignored)
REVIEWER_USER_ID=

# Group chat id where daily reminders are posted (negative number for groups)
GROUP_CHAT_ID=

# Turso / libSQL
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Secrets — never copy real env files into the image.
.env
.env.*
!.env.example

# Local virtualenv (rebuilt inside the image).
.venv

# VCS / CI
.git
.gitignore

# Python caches
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Local test artifacts and sample audio — must not leak into the image.
test_samples/

# Local scratch
main.py
